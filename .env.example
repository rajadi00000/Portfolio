# ─── Portfolio — Personal Info ────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and never committed.
#
# Vite ONLY exposes variables prefixed with VITE_ to the browser bundle.
# Never put secrets/tokens here — this is a public static site.

VITE_NAME="Your Full Name"
VITE_TITLE="Software Engineer"
VITE_TAGLINE="Building for iOS · Web · AI"
VITE_SUMMARY="Your professional summary here."
VITE_LOCATION="City, Country"
VITE_EMAIL="you@example.com"
VITE_PHONE="+91 00000 00000"
VITE_LINKEDIN="https://linkedin.com/in/yourhandle"
VITE_GITHUB="https://github.com/yourhandle"

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to show the "↓ Resume" download button in the navbar.
# (Legacy single-flag; superseded by VITE_FLAG_SHOW_RESUME_PDF below when both are set.)
VITE_SHOW_RESUME_DOWNLOAD=true

# Optional: URL to a remote JSON file with feature flags.
# If set, flags are fetched at runtime — update the JSON anytime without redeploying.
# Leave blank to fall back to VITE_FLAG_SHOW_* env vars (or hardcoded defaults).
#
# Example sources:
#   GitHub Gist (public): https://gist.githubusercontent.com/<user>/<id>/raw/flags.json
#   Vercel Edge Config:    https://edge-config.vercel.com/<id>?token=<token>
#   Any public HTTPS URL returning {"showResumePDF": true, ...}
VITE_FEATURE_FLAGS_URL=

# ─── Per-feature env-var overrides ────────────────────────────────────────────
# Priority: Remote Gist (VITE_FEATURE_FLAGS_URL) > these env vars > hardcoded defaults
# Env var name = "VITE_" + the flag key used in the Gist JSON (same name, same value).
# Values: "true" / "false" / "0"  (any non-empty value except "false"/"0" → true)
#
# Show the PDF download button inside the resume modal (default: true)
VITE_showResumePDF=true
# Show the DOCX download button inside the resume modal (default: true)
VITE_showResumeDocx=true
# Show the Projects section and its nav link (default: true)
VITE_showProjects=true
# Show the Accomplishments section (default: true)
VITE_showAccomplishments=true
# Show the Contact CTA link in the navbar (default: false)
VITE_showContactForm=false
